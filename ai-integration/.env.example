# ─────────────────────────────────────────────────────────────────────────────
# .env.example  (copy to .env and fill in your values)
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=midday
POSTGRES_PASSWORD=midday_password
POSTGRES_DB=midday_meal_ai
DATABASE_URL=postgresql://midday:midday_password@postgres:5432/midday_meal_ai?schema=public

# ── API Server ────────────────────────────────────────────────────────────────
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=1d
API_PORT=4000
AI_SERVICE_URL=http://ai-service:8000

# ── Frontend ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000

# ── AI Engine ─────────────────────────────────────────────────────────────────
# Which provider to use: gemini | mock
# Use "mock" during development to avoid API costs.
# Switch to "gemini" in staging/production.
AI_PROVIDER=gemini

# Your Google Gemini API key — get from https://aistudio.google.com/app/apikey
# Leave blank to force fallback to rules engine (app stays functional).
GEMINI_API_KEY=

# Gemini model name — change to upgrade without code changes
# Options: gemini-2.5-flash | gemini-2.5-pro | gemini-1.5-pro
MODEL_NAME=gemini-2.5-flash

# Request timeout in milliseconds (default 30s)
AI_TIMEOUT_MS=30000
